<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hugo.bikealert</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/hugo/PycharmProjects/PythonProject/.venv/bin/python</string>
        <string>/Users/hugo/PycharmProjects/PythonProject/bike_alert/bike_alert.py</string>
        <string>--once</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/hugo/PycharmProjects/PythonProject/bike_alert</string>

    <!-- Run every 300s (5 min). Skipped while Mac sleeps; runs once on wake. -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Run once immediately when loaded. -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/hugo/PycharmProjects/PythonProject/bike_alert/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/hugo/PycharmProjects/PythonProject/bike_alert/launchd.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
